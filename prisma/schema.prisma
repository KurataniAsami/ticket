generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id            Int     @id @default(autoincrement())
  EventTitle         String?
  artist        String
  artistImage   String?   // アーティストは必須項目だが、artist登録時には画像が存在しないから?にする
  eventDate     DateTime
  ticketImage   String?
  note          String?
  songList      String?
  rating        Int?   // レビュー

  // 画像が0件でも空配列になるからオプショナルにしなくてもいい
  // memoryImage   String[]

  placeId       Int
  place         Place     @relation(fields: [placeId], references: [id])

  eventImages    EventImage[]
}

model EventImage {
  id            Int     @id @default(autoincrement())
  url           String      // 存在するならurlは必ず持つ必要があるので?にしない
  comment       String?

  eventId       Int
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Place {
  id      Int           @id @default(autoincrement())
  name    String?
  events  Event[]
}


// 別のプロジェクトのテーブル
model Pokemon {
  id      Int           @id @default(autoincrement())
  name    String
  weight  Int
  detail  String @default("")
  types   PokemonType[]
}

model Type {
  id        Int           @id @default(autoincrement())
  name      String
  pokemons  PokemonType[]
}

model PokemonType {
  id          Int     @id @default(autoincrement())
  pokemonId   Int
  typeId      Int     @map("type_id")
  pokemon     Pokemon @relation(fields: [pokemonId], references: [id], onDelete: Cascade)
  type        Type    @relation(fields: [typeId], references: [id], onDelete: Cascade)
}
