generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id            Int     @id @default(autoincrement())
  title         String?
  artist        String?
  eventDate     DateTime
  ticketImage   String?
  note          String?
  memoryImage   String?

  placeId       Int
  place        Place     @relation(fields: [placeId], references: [id])
}

model Place {
  id      Int           @id @default(autoincrement())
  name    String?
  events  Event[]
}


// 別のプロジェクトのテーブル
model Pokemon {
  id      Int           @id @default(autoincrement())
  name    String
  weight  Int
  detail  String @default("")
  types   PokemonType[]
}

model Type {
  id        Int           @id @default(autoincrement())
  name      String
  pokemons  PokemonType[]
}

model PokemonType {
  id          Int     @id @default(autoincrement())
  pokemonId   Int
  typeId      Int     @map("type_id")
  pokemon     Pokemon @relation(fields: [pokemonId], references: [id], onDelete: Cascade)
  type        Type    @relation(fields: [typeId], references: [id], onDelete: Cascade)
}
