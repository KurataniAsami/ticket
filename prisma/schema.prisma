generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Artist ↔ Event（多対多）
model Event {
  id              Int     @id @default(autoincrement())
  eventTitle      String?
  eventDate       DateTime
  ticketImageKey  String?
  note            String?
  songList        String?
  rating          Int?   // レビュー

  // 画像が0件でも空配列になるからオプショナルにしなくてもいい
  // memoryImage   String[]

  placeId         Int
  place           Place     @relation(fields: [placeId], references: [id])

  eventImages     EventImage[]
  artist          Artist[]
}

model Artist {
  id              Int     @id @default(autoincrement())
  name            String  @unique    // 同一アーティストを重複させない
  imageUrl        String?
  events          Event[]
}

model Place {
  id              Int           @id @default(autoincrement())
  name            String
  events          Event[]
}

model EventImage {
  id              Int     @id @default(autoincrement())
  url             String      // 存在するならurlは必ず持つ必要があるので?にしない
  comment         String?

  eventId         Int
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

